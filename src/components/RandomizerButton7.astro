---
interface Props {
  audioBufferVar?: string;
  ctxVar?: string;
  applyLoopVar?: string;
}
const { audioBufferVar = 'currentAudioBuffer', ctxVar = 'audioContext', applyLoopVar = 'applyLoop' } = Astro.props

---

<button
  class="loop-btn"
  id="randomizeLoopBtn7"
  data-buffer-var={audioBufferVar}
  data-ctx-var={ctxVar}
  data-apply-loop-var={applyLoopVar}
>
  🌀 Aphex Polyrhythm
</button>

<script>
  import { halfLoop, doubleLoop, moveForward, reverseBufferSection, resetLoop, detectLoop } from '../core/index.js';
  import { enqueueToast } from '../scripts/ui/toastQueue.js';
  
  function aphexPolyrhythm(buffer, { steps = 48 } = {}) {
    let loop = detectLoop(buffer);
    const sequence = [];
    
    // Complex Aphex-inspired pattern with polyrhythmic elements
    const aphexPattern = [
      // Phase 1: Fragmentation - break into micro-loops
      'half', 'half', 'reverse', 'move',
      'half', 'reverse', 'half', 'move',
      
      // Phase 2: Polyrhythmic layering - overlapping time signatures  
      'polyrhythm3', 'reverse', 'move', 'half',
      'polyrhythm5', 'reverse', 'move', 'double',
      
      // Phase 3: Temporal displacement - time-stretching effects
      'stretch', 'reverse', 'compress', 'move',
      'half', 'stretch', 'reverse', 'half',
      
      // Phase 4: Chaos injection - rapid manipulations
      'reverse', 'half', 'reverse', 'move',
      'half', 'reverse', 'half', 'reverse',
      
      // Phase 5: Reconstruction - building back complexity
      'double', 'polyrhythm3', 'reverse', 'move',
      'double', 'stretch', 'reverse', 'polyrhythm5',
      
      // Phase 6: Final spiral - descending into chaos
      'half', 'reverse', 'half', 'reverse',
      'half', 'reverse', 'half', 'move',
      'reset', 'half', 'reverse', 'end'
    ];
    
    for (let i = 0; i < steps; i++) {
      const action = aphexPattern[i % aphexPattern.length];
      
      const fn = () => {
        switch (action) {
          case 'half':
            if (loop.endSample - loop.startSample >= 2 * (10 / 1000) * buffer.sampleRate) {
              loop = halfLoop(loop);
            }
            break;
          case 'double':
            loop = doubleLoop(loop, buffer.length);
            break;
          case 'move':
            const duration = loop.endSample - loop.startSample;
            const newStart = loop.startSample + duration;
            const newEnd = loop.endSample + duration;
            if (newEnd <= buffer.length) {
              loop = { startSample: newStart, endSample: newEnd };
            }
            break;
          case 'reverse':
            buffer = reverseBufferSection(buffer, loop.startSample, loop.endSample);
            break;
          case 'polyrhythm3':
            // Create 3:4 polyrhythm by subdividing loop
            const poly3Duration = Math.floor((loop.endSample - loop.startSample) / 3);
            loop = { 
              startSample: loop.startSample, 
              endSample: loop.startSample + poly3Duration 
            };
            break;
          case 'polyrhythm5':
            // Create 5:4 polyrhythm
            const poly5Duration = Math.floor((loop.endSample - loop.startSample) * 5 / 4);
            if (loop.startSample + poly5Duration <= buffer.length) {
              loop = { 
                startSample: loop.startSample, 
                endSample: loop.startSample + poly5Duration 
              };
            }
            break;
          case 'stretch':
            // Time-stretch effect by doubling loop and halving playback
            const stretchLoop = doubleLoop(loop, buffer.length);
            loop = stretchLoop;
            break;
          case 'compress':
            // Time-compress by halving and rapid playback
            if (loop.endSample - loop.startSample >= 4 * (10 / 1000) * buffer.sampleRate) {
              loop = halfLoop(loop);
              loop = halfLoop(loop); // Double compression
            }
            break;
          case 'reset':
            loop = resetLoop(buffer);
            break;
          case 'end':
            // Dramatic ending - reverse entire processed section
            buffer = reverseBufferSection(buffer, 0, buffer.length);
            break;
        }
        return { buffer, loop, op: action };
      };
      fn.op = action;
      sequence.push(fn);
    }
    
    return sequence;
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('randomizeLoopBtn7');
    btn?.addEventListener('click', async () => {
      const buffer = window[btn.dataset.bufferVar];
      const ctx = window[btn.dataset.ctxVar];
      const applyLoop = window[btn.dataset.applyLoopVar];
      if (!buffer || !ctx || typeof applyLoop !== 'function') return;
      
      const seq = aphexPolyrhythm(buffer, { steps: 48 });
      enqueueToast('🌀 Aphex polyrhythmic sequence: ' + seq.map(fn => fn.op).join(' → '));
      
      let buf = buffer;
      let phaseCounter = 0;
      
      for (const step of seq) {
        const { buffer: newBuf, loop } = step();
        buf = newBuf;
        applyLoop(buf, loop, step.op, undefined);
        
        // Variable timing based on operation type
        let timing = 100;
        if (step.op.includes('poly')) timing = 180; // Slower for polyrhythms
        if (step.op === 'stretch') timing = 250; // Even slower for stretching
        if (step.op === 'reverse' && Math.random() < 0.3) timing = 80; // Sometimes rapid reverse
        
        await new Promise(r => setTimeout(r, timing));
        
        // Phase announcements
        phaseCounter++;
        if (phaseCounter === 8) enqueueToast('🔀 Phase 2: Polyrhythmic layering');
        if (phaseCounter === 16) enqueueToast('⏰ Phase 3: Temporal displacement');
        if (phaseCounter === 24) enqueueToast('💥 Phase 4: Chaos injection');
        if (phaseCounter === 32) enqueueToast('🏗️ Phase 5: Reconstruction');
        if (phaseCounter === 40) enqueueToast('🌪️ Phase 6: Final spiral');
      }
      
      enqueueToast('🌀 Aphex polyrhythmic sequence complete');
    });
  });
</script>