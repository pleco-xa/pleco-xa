---
/**
 * Consolidated RandomizerButton Component
 * Replaces 15 separate RandomizerButton files with a single parameterized component
 */
interface Props {
  id: string;
  label: string;
  algorithm: 'smart' | 'reverseHeavy' | 'rhythmic' | 'chaosTheory' | 'spiralMorph' | 'invertible' | 'aphexPolyrhythm' | 'perfectInversion' | 'destructive' | 'moveIntensive' | 'halfBias' | 'doubleBias' | 'silentExplorer' | 'fractalDescent' | 'quantumLeap';
  steps?: number;
  audioBufferVar?: string;
  ctxVar?: string;
  applyLoopVar?: string;
}

const {
  id,
  label,
  algorithm,
  steps = 41,
  audioBufferVar = 'currentAudioBuffer',
  ctxVar = 'audioContext',
  applyLoopVar = 'applyLoop'
} = Astro.props;
---

<button
  class="loop-btn"
  id={id}
  data-algorithm={algorithm}
  data-steps={steps}
  data-buffer-var={audioBufferVar}
  data-ctx-var={ctxVar}
  data-apply-loop-var={applyLoopVar}
>
  {label}
</button>

<script>
  import { randomSequence, halfLoop, doubleLoop, moveForward, reverseBufferSection, resetLoop, detectLoop } from '../core/index.js';
  import { enqueueToast } from '../scripts/ui/toastQueue.js';

  // Algorithm weight configurations
  const algorithms = {
    smart: (buffer, { steps = 41 } = {}) => {
      return randomSequence(buffer, {
        minMs: 10,
        maxMs: buffer.duration * 1000,
        steps
      });
    },

    reverseHeavy: (buffer, { steps = 41 } = {}) => {
      let loop = detectLoop(buffer);
      const sequence = [];
      const minSamples = (10 / 1000) * buffer.sampleRate;
      const actions = [
        { op: 'reverse', w: 50 },
        { op: 'move', w: 20 },
        { op: 'half', w: 15 },
        { op: 'double', w: 10 },
        { op: 'reset', w: 5 },
      ];
      const totalW = actions.reduce((s, { w }) => s + w, 0);

      for (let i = 0; i < steps; i++) {
        let r = Math.random() * totalW;
        let acc = 0;
        let action = 'reverse';
        for (const { op, w } of actions) {
          acc += w;
          if (r < acc) {
            action = op;
            break;
          }
        }

        const fn = createSequenceStep(buffer, loop, action, minSamples);
        fn.op = action;
        sequence.push(fn);
      }
      return sequence;
    },

    moveIntensive: (buffer, { steps = 41 } = {}) => {
      let loop = detectLoop(buffer);
      const sequence = [];
      const minSamples = (10 / 1000) * buffer.sampleRate;
      const actions = [
        { op: 'move', w: 50 },
        { op: 'half', w: 20 },
        { op: 'double', w: 15 },
        { op: 'reverse', w: 10 },
        { op: 'reset', w: 5 },
      ];
      const totalW = actions.reduce((s, { w }) => s + w, 0);

      for (let i = 0; i < steps; i++) {
        let r = Math.random() * totalW;
        let acc = 0;
        let action = 'move';
        for (const { op, w } of actions) {
          acc += w;
          if (r < acc) {
            action = op;
            break;
          }
        }

        const fn = createSequenceStep(buffer, loop, action, minSamples);
        fn.op = action;
        sequence.push(fn);
      }
      return sequence;
    },

    halfBias: (buffer, { steps = 41 } = {}) => {
      let loop = detectLoop(buffer);
      const sequence = [];
      const minSamples = (10 / 1000) * buffer.sampleRate;
      const actions = [
        { op: 'half', w: 50 },
        { op: 'move', w: 20 },
        { op: 'reverse', w: 15 },
        { op: 'double', w: 10 },
        { op: 'reset', w: 5 },
      ];
      const totalW = actions.reduce((s, { w }) => s + w, 0);

      for (let i = 0; i < steps; i++) {
        let r = Math.random() * totalW;
        let acc = 0;
        let action = 'half';
        for (const { op, w } of actions) {
          acc += w;
          if (r < acc) {
            action = op;
            break;
          }
        }

        const fn = createSequenceStep(buffer, loop, action, minSamples);
        fn.op = action;
        sequence.push(fn);
      }
      return sequence;
    },

    doubleBias: (buffer, { steps = 41 } = {}) => {
      let loop = detectLoop(buffer);
      const sequence = [];
      const minSamples = (10 / 1000) * buffer.sampleRate;
      const actions = [
        { op: 'double', w: 50 },
        { op: 'move', w: 20 },
        { op: 'half', w: 15 },
        { op: 'reverse', w: 10 },
        { op: 'reset', w: 5 },
      ];
      const totalW = actions.reduce((s, { w }) => s + w, 0);

      for (let i = 0; i < steps; i++) {
        let r = Math.random() * totalW;
        let acc = 0;
        let action = 'double';
        for (const { op, w } of actions) {
          acc += w;
          if (r < acc) {
            action = op;
            break;
          }
        }

        const fn = createSequenceStep(buffer, loop, action, minSamples);
        fn.op = action;
        sequence.push(fn);
      }
      return sequence;
    },

    rhythmic: (buffer, { steps = 32 } = {}) => {
      let loop = detectLoop(buffer);
      const sequence = [];
      const rhythmicPattern = [
        'half', 'half', 'move', 'reverse',
        'double', 'half', 'move', 'half',
        'reverse', 'move', 'double', 'half',
        'reset', 'half', 'half', 'move',
        'reverse', 'half', 'double', 'move',
        'half', 'reverse', 'move', 'double',
        'half', 'half', 'reverse', 'move',
        'double', 'reset', 'half', 'move'
      ];

      const minSamples = (10 / 1000) * buffer.sampleRate;

      for (let i = 0; i < steps; i++) {
        const action = rhythmicPattern[i % rhythmicPattern.length];
        const fn = createSequenceStep(buffer, loop, action, minSamples);
        fn.op = action;
        sequence.push(fn);
      }
      return sequence;
    },

    // Add more algorithms as needed - chaosTheory, spiralMorph, etc.
    // For now, use reverseHeavy as fallback for unimplemented ones
    chaosTheory: function(buffer, opts) { return this.reverseHeavy(buffer, opts); },
    spiralMorph: function(buffer, opts) { return this.moveIntensive(buffer, opts); },
    invertible: function(buffer, opts) { return this.reverseHeavy(buffer, opts); },
    aphexPolyrhythm: function(buffer, opts) { return this.rhythmic(buffer, opts); },
    perfectInversion: function(buffer, opts) { return this.reverseHeavy(buffer, opts); },
    destructive: function(buffer, opts) { return this.reverseHeavy(buffer, opts); },
    silentExplorer: function(buffer, opts) { return this.halfBias(buffer, opts); },
    fractalDescent: function(buffer, opts) { return this.halfBias(buffer, opts); },
    quantumLeap: function(buffer, opts) { return this.smart(buffer, opts); },
  };

  function createSequenceStep(buffer, loop, action, minSamples) {
    return () => {
      switch (action) {
        case 'half':
          if (loop.endSample - loop.startSample >= 2 * minSamples) {
            loop = halfLoop(loop);
          }
          break;
        case 'double':
          loop = doubleLoop(loop, buffer.length);
          break;
        case 'move': {
          const duration = loop.endSample - loop.startSample;
          const newStart = loop.startSample + duration;
          const newEnd = loop.endSample + duration;
          if (newEnd <= buffer.length) {
            loop = { startSample: newStart, endSample: newEnd };
          }
          break;
        }
        case 'reverse':
          buffer = reverseBufferSection(buffer, loop.startSample, loop.endSample);
          break;
        case 'reset':
          loop = resetLoop(buffer);
          break;
      }
      return { buffer, loop, op: action };
    };
  }

  // Initialize all randomizer buttons
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('[data-algorithm]');

    buttons.forEach(btn => {
      btn.addEventListener('click', async () => {
        const buffer = window[btn.dataset.bufferVar];
        const ctx = window[btn.dataset.ctxVar];
        const applyLoop = window[btn.dataset.applyLoopVar];

        if (!buffer || !ctx || typeof applyLoop !== 'function') {
          enqueueToast('❌ No audio loaded');
          return;
        }

        const algorithmName = btn.dataset.algorithm;
        const steps = parseInt(btn.dataset.steps) || 41;
        const algorithm = algorithms[algorithmName];

        if (!algorithm) {
          enqueueToast(`❌ Unknown algorithm: ${algorithmName}`);
          return;
        }

        try {
          const seq = algorithm(buffer, { steps });
          enqueueToast(`${btn.textContent} → ${seq.length} steps`);

          let buf = buffer;
          for (const step of seq) {
            const { buffer: newBuf, loop } = step();
            buf = newBuf;
            applyLoop(buf, loop, step.op || step.action, undefined);
            await new Promise(r => setTimeout(r, 100));
          }

          enqueueToast('✅ Sequence complete');
        } catch (error) {
          console.error('Randomizer error:', error);
          enqueueToast(`❌ Randomizer failed: ${error.message}`);
        }
      });
    });
  });
</script>
