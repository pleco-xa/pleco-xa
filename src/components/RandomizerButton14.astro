---
interface Props {
  audioBufferVar?: string;
  ctxVar?: string;
  applyLoopVar?: string;
}
const { audioBufferVar = 'currentAudioBuffer', ctxVar = 'audioContext', applyLoopVar = 'applyLoop' } = Astro.props

---

<button
  class="loop-btn"
  id="randomizeLoopBtn14"
  data-buffer-var={audioBufferVar}
  data-ctx-var={ctxVar}
  data-apply-loop-var={applyLoopVar}
>
  🌀 Chaos Theory
</button>

<script>
  import { detectLoop } from '../core/index.js';
  import { enqueueToast } from '../scripts/ui/toastQueue.js';
  import { generateChaotic, executeOperation } from '../scripts/algorithmic-sequences.js';
  
  function createChaoticSequence(buffer, { steps = 256 } = {}) {
    let loop = detectLoop(buffer);
    const sequence = [];
    const actionSequence = generateChaotic(steps);
    
    // Chaotic system phases based on logistic map behavior
    const sections = {
      "🌱 Initial Conditions": actionSequence.slice(0, Math.floor(steps * 0.1)),
      "📈 Linear Growth": actionSequence.slice(Math.floor(steps * 0.1), Math.floor(steps * 0.25)),
      "🔄 Periodic Cycles": actionSequence.slice(Math.floor(steps * 0.25), Math.floor(steps * 0.5)),
      "⚡ Bifurcation Cascade": actionSequence.slice(Math.floor(steps * 0.5), Math.floor(steps * 0.75)),
      "🌪️ Strange Attractor": actionSequence.slice(Math.floor(steps * 0.75), Math.floor(steps * 0.9)),
      "💥 Butterfly Effect": actionSequence.slice(Math.floor(steps * 0.9))
    };
    
    const createSectionSequence = (section, sectionName) => {
      return section.map((action, idx) => {
        return () => {
          const result = executeOperation(action, buffer, loop);
          buffer = result.buffer;
          loop = result.loop;
          
          return {
            buffer: result.buffer,
            loop: result.loop,
            op: `${sectionName}-${action}-${idx+1}`
          };
        };
      });
    };
    
    Object.entries(sections).forEach(([sectionName, sectionActions]) => {
      sequence.push(...createSectionSequence(sectionActions, sectionName));
    });
    
    return sequence;
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('randomizeLoopBtn14');
    btn?.addEventListener('click', async () => {
      const buffer = window[btn.dataset.bufferVar];
      const ctx = window[btn.dataset.ctxVar];
      const applyLoop = window[btn.dataset.applyLoopVar];
      
      if (!buffer || !ctx || typeof applyLoop !== 'function') return;
      
      const seq = createChaoticSequence(buffer, { steps: 256 });
      enqueueToast('🌀 Chaos Theory: Deterministic Randomness Unleashed');
      
      let buf = buffer;
      let currentLoop = detectLoop(buf);
      let section = "";
      let stepCount = 0;
      
      // Initialize chaotic variables for timing
      let x = 0.5;
      const r = 3.99;
      
      for (const step of seq) {
        const result = step();
        buf = result.buffer;
        currentLoop = result.loop;
        
        // Detect section changes
        const newSection = result.op.split('-')[0];
        if (newSection !== section) {
          enqueueToast(`${newSection}`);
          section = newSection;
        }
        
        applyLoop(buf, currentLoop, result.op, undefined);
        
        // Chaotic timing based on logistic map
        x = r * x * (1 - x);
        const baseTime = 80;
        const chaoticMultiplier = 1 + (x * 3); // 1-4x multiplier
        let timing = baseTime * chaoticMultiplier;
        
        // Section-specific chaos behavior
        if (section.includes("Initial")) timing *= 2; // Slow start
        if (section.includes("Bifurcation")) timing *= 0.5; // Rapid changes
        if (section.includes("Strange")) timing = baseTime + (Math.sin(stepCount) * 50); // Oscillating
        if (section.includes("Butterfly")) timing = 50 + (Math.random() * 200); // Pure chaos
        
        // Anti-micro-chaos protection - prevent insane speeds
        const minTiming = 70;
        const maxChaosSequence = 4; // Max consecutive chaotic fast operations
        if (timing < minTiming) {
          const chaosCount = (window.chaosSequenceCount || 0) + 1;
          window.chaosSequenceCount = chaosCount;
          
          if (chaosCount > maxChaosSequence) {
            timing = baseTime * 1.5; // Slow down for a moment
            window.chaosSequenceCount = 0;
            enqueueToast('🌪️ Chaos controlled - breathing space');
          }
        } else {
          window.chaosSequenceCount = 0; // Reset counter
        }
        
        stepCount++;
        await new Promise(r => setTimeout(r, Math.abs(timing)));
      }
      
      enqueueToast('🌀 Chaos Theory Complete - Order from Disorder Achieved');
    });
  });
</script>