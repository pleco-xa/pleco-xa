---
interface Props {
  audioBufferVar?: string;
  ctxVar?: string;
  applyLoopVar?: string;
}
const { audioBufferVar = 'currentAudioBuffer', ctxVar = 'audioContext', applyLoopVar = 'applyLoop' } = Astro.props

---

<button
  class="loop-btn"
  id="randomizeLoopBtn9"
  data-buffer-var={audioBufferVar}
  data-ctx-var={ctxVar}
  data-apply-loop-var={applyLoopVar}
>
  💥 Destructive Symphony
</button>

<script>
  import { halfLoop, doubleLoop, moveForward, reverseBufferSection, resetLoop, detectLoop } from '../core/index.js';
  import { enqueueToast } from '../scripts/ui/toastQueue.js';
  
  /** 1-liner inverse of moveForward (same Δ but negative). */
  function moveBackward(loop) {
    const span = loop.endSample - loop.startSample;
    return {
      startSample: loop.startSample - span,
      endSample: loop.endSample - span
    };
  }

  /** Low-level executor – mutates `buffer`/`loop` in-place. */
  function applyOp(op, buffer, loop) {
    switch (op) {
      case 'half':    return { buffer, loop: halfLoop(loop) };
      case 'double':  return { buffer, loop: doubleLoop(loop, buffer.length) };
      case 'reverse': return {
        buffer: reverseBufferSection(buffer, loop.startSample, loop.endSample),
        loop
      };
      case 'moveF':   return { buffer, loop: moveForward(loop, buffer.length) };
      case 'moveB':   return { buffer, loop: moveBackward(loop) };
      default: throw new Error(`Unknown op "${op}"`);
    }
  }

  /** Build destructive symphony sequence pair */
  function buildDestructiveSymphony() {
    // Extremely destructive 3-minute song-like sequence
    const seqA = [
      // Movement 1: Fragmentation (bars 1-8)
      'half', 'half', 'half', 'reverse', 'moveF', 'reverse',
      'half', 'reverse', 'moveF', 'half', 'reverse', 'moveF',
      
      // Movement 2: Chaos (bars 9-16) 
      'reverse', 'half', 'reverse', 'half', 'reverse', 'moveF',
      'half', 'half', 'reverse', 'moveF', 'reverse', 'half',
      
      // Movement 3: Expansion (bars 17-24)
      'double', 'reverse', 'moveF', 'double', 'reverse', 'moveF',
      'reverse', 'double', 'half', 'reverse', 'moveF', 'double',
      
      // Movement 4: Violent Deconstruction (bars 25-32)
      'half', 'reverse', 'half', 'reverse', 'half', 'reverse',
      'moveF', 'half', 'reverse', 'moveF', 'half', 'reverse',
      
      // Movement 5: Reconstruction (bars 33-40)
      'double', 'moveF', 'reverse', 'double', 'moveF', 'reverse',
      'double', 'double', 'reverse', 'moveF', 'reverse', 'half',
      
      // Movement 6: Final Destruction (bars 41-48)
      'reverse', 'half', 'reverse', 'moveF', 'half', 'reverse',
      'moveF', 'reverse', 'half', 'half', 'reverse', 'moveF'
    ];

    // Mechanically create perfect inverse
    const inverseMap = { 
      half: 'double', 
      double: 'half', 
      reverse: 'reverse', 
      moveF: 'moveB', 
      moveB: 'moveF' 
    };
    const seqB = [...seqA].reverse().map(op => inverseMap[op]);

    return { seqA, seqB };
  }

  /** Run destructive symphony with movement announcements */
  async function runDestructiveSymphony(buffer, applyLoop, tickMs = 100) {
    let loop = detectLoop(buffer);
    let curBuf = buffer;
    const { seqA, seqB } = buildDestructiveSymphony();

    // Movement markers
    const movements = [
      { start: 0, name: '🔪 Movement I: Fragmentation' },
      { start: 12, name: '💥 Movement II: Chaos' },
      { start: 24, name: '🌊 Movement III: Expansion' },
      { start: 36, name: '⚡ Movement IV: Violent Deconstruction' },
      { start: 48, name: '🏗️ Movement V: Reconstruction' },
      { start: 60, name: '🌪️ Movement VI: Final Destruction' }
    ];

    const play = async (ops, label) => {
      console.log(`⟶ Playing ${label}:`, ops.join(' → '));
      enqueueToast(`${label} - ${ops.length} operations`);
      
      for (let i = 0; i < ops.length; i++) {
        const op = ops[i];
        
        // Announce movements
        const movement = movements.find(m => m.start === i);
        if (movement) {
          enqueueToast(movement.name);
          await new Promise(r => setTimeout(r, 300)); // Brief pause for announcement
        }
        
        ({ buffer: curBuf, loop } = applyOp(op, curBuf, loop));
        applyLoop(curBuf, loop, op);
        
        // Variable timing based on intensity
        let timing = tickMs;
        if (op === 'reverse') timing = tickMs * 0.8; // Faster reverses
        if (op === 'half') timing = tickMs * 0.6; // Rapid fragmentation
        if (i >= 36 && i < 48) timing = tickMs * 0.5; // Violent deconstruction is fastest
        
        // Anti-destruction protection - prevent getting stuck in violence
        const minTiming = 60;
        const maxDestructionSequence = 5;
        if (timing < minTiming) {
          const destructionCount = (window.destructionSequenceCount || 0) + 1;
          window.destructionSequenceCount = destructionCount;
          
          if (destructionCount > maxDestructionSequence) {
            timing = tickMs * 1.2; // Slow down the destruction
            window.destructionSequenceCount = 0;
            enqueueToast('💥 Destruction slowed - tactical pause');
          }
        } else {
          window.destructionSequenceCount = 0;
        }
        
        await new Promise(r => setTimeout(r, timing));
      }
    };

    await play(seqA, '💥 Destructive Symphony (Forward)');
    await new Promise(r => setTimeout(r, 1000)); // Dramatic pause
    enqueueToast('🔄 Beginning Perfect Reconstruction...');
    await play(seqB, '↩️ Perfect Reconstruction (Inverse)');
    enqueueToast('✅ Destructive Symphony Complete - Perfect Return to Origin');
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('randomizeLoopBtn9');
    btn?.addEventListener('click', async () => {
      const buffer = window[btn.dataset.bufferVar];
      const ctx = window[btn.dataset.ctxVar];
      const applyLoop = window[btn.dataset.applyLoopVar];
      if (!buffer || !ctx || typeof applyLoop !== 'function') return;
      
      await runDestructiveSymphony(buffer, applyLoop, 120); // 120ms = aggressive timing
    });
  });
</script>