---
import MainLayout from '../components/MainLayout.astro';

const title = 'Vocal Separation - Pleco XA';
const description = 'Multi-scale spectral fingerprinting vocal separation demo';
---

<MainLayout {...{title, description}}>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #0a0a0a;
      color: #e0e0e0;
      padding: 20px;
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
    }

    h1 {
      margin-bottom: 10px;
      color: #00ff88;
      font-size: 2rem;
    }

    .subtitle {
      color: #888;
      margin-bottom: 30px;
    }

    .description {
      background: #1a1a1a;
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 30px;
      line-height: 1.6;
    }

    .controls {
      background: #1a1a1a;
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 20px;
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
      align-items: center;
    }

    .control-group {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    label {
      font-size: 0.85rem;
      color: #aaa;
    }

    select, button, input[type="file"] {
      padding: 8px 12px;
      background: #2a2a2a;
      border: 1px solid #444;
      border-radius: 4px;
      color: #e0e0e0;
      cursor: pointer;
      font-size: 0.9rem;
    }

    button {
      background: #00ff88;
      color: #0a0a0a;
      font-weight: 600;
      border: none;
      transition: background 0.2s;
    }

    button:hover {
      background: #00dd77;
    }

    button:disabled {
      background: #444;
      color: #888;
      cursor: not-allowed;
    }

    .status {
      background: #1a1a1a;
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 20px;
      font-size: 0.9rem;
    }

    .spectrogram-section {
      background: #1a1a1a;
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 20px;
    }

    .spectrogram-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 20px;
    }

    canvas {
      width: 100%;
      height: auto;
      border-radius: 4px;
      background: #000;
    }

    .fingerprints-section {
      background: #1a1a1a;
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 20px;
    }

    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
      font-size: 0.8rem;
    }

    .metric-item {
      background: #2a2a2a;
      padding: 10px;
      border-radius: 4px;
    }

    .metric-label {
      color: #888;
      margin-bottom: 3px;
    }

    .metric-value {
      color: #00ff88;
      font-weight: 600;
    }

    .error {
      background: #ff3333;
      color: white;
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 20px;
    }

    .progress {
      background: #2a2a2a;
      border-radius: 4px;
      height: 20px;
      margin-bottom: 10px;
      overflow: hidden;
    }

    .progress-bar {
      background: #00ff88;
      height: 100%;
      width: 0%;
      transition: width 0.3s;
    }

    .results {
      background: #1a1a1a;
      padding: 20px;
      border-radius: 8px;
    }

    .results-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .audio-player {
      background: #2a2a2a;
      padding: 15px;
      border-radius: 4px;
      margin-top: 10px;
    }

    audio {
      width: 100%;
    }
  </style>

  <div class="container">
    <h1>Vocal Separation Demo</h1>
    <p class="subtitle">Multi-scale spectral fingerprinting using Pleco XA</p>

    <div class="description">
      <p>This demo recreates the vocal separation approach from the Python demo using JavaScript. It uses multi-scale spectral fingerprinting to separate vocals from a mixture without neural network training.</p>
      <p><strong>Process:</strong></p>
      <ol>
        <li>Load isolated vocal and mixture audio files</li>
        <li>Create 18 different spectrogram slices with various convolutions</li>
        <li>Extract 425-point fingerprints from each time window</li>
        <li>Optimize EQ curves to match mixture fingerprints to vocal fingerprints</li>
        <li>Reconstruct separated vocal audio</li>
      </ol>
      <p><strong>Note:</strong> This is a computational demo. For best results, use audio files with clear vocal/instrumental separation.</p>
    </div>

    <div id="error" class="error" style="display: none;"></div>

    <div class="controls">
      <div class="control-group">
        <label for="vocalFile">Vocal Audio File</label>
        <input type="file" id="vocalFile" accept="audio/*">
      </div>

      <div class="control-group">
        <label for="mixtureFile">Mixture Audio File</label>
        <input type="file" id="mixtureFile" accept="audio/*">
      </div>

      <button id="runSeparationBtn">Run Vocal Separation</button>
      <button id="generateSyntheticBtn">Generate Synthetic Demo</button>
    </div>

    <div id="status" class="status" style="display: none;">
      <div>Status: <span id="statusText">Initializing...</span></div>
      <div class="progress">
        <div class="progress-bar" id="progressBar"></div>
      </div>
    </div>

    <div id="spectrograms" class="spectrogram-section" style="display: none;">
      <h2>Spectrograms</h2>
      <div class="spectrogram-container">
        <div>
          <h3>Target Vocal</h3>
          <canvas id="vocalSpectrogram" width="600" height="300"></canvas>
        </div>
        <div>
          <h3>Original Mixture</h3>
          <canvas id="mixtureSpectrogram" width="600" height="300"></canvas>
        </div>
      </div>
      <div class="spectrogram-container">
        <div>
          <h3>Extracted Vocal</h3>
          <canvas id="extractedSpectrogram" width="600" height="300"></canvas>
        </div>
        <div>
          <h3>Slice Example (Raw)</h3>
          <canvas id="sliceSpectrogram" width="600" height="300"></canvas>
        </div>
      </div>
    </div>

    <div id="fingerprints" class="fingerprints-section" style="display: none;">
      <h2>Fingerprint Comparison (Window 0)</h2>
      <div class="metrics-grid" id="metricsGrid">
        <!-- Metrics will be populated here -->
      </div>
    </div>

    <div id="results" class="results" style="display: none;">
      <h2>Results</h2>
      <div class="results-grid">
        <div class="audio-player">
          <h3>Original Mixture</h3>
          <audio id="mixtureAudio" controls></audio>
        </div>
        <div class="audio-player">
          <h3>Target Vocal</h3>
          <audio id="vocalAudio" controls></audio>
        </div>
      </div>
      <div class="results-grid">
        <div class="audio-player">
          <h3>Extracted Vocal</h3>
          <audio id="extractedAudio" controls></audio>
        </div>
        <div>
          <h3>Optimization Results</h3>
          <div id="optimizationResults"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Wave 6: processed script consuming the pleco-xa package (the old
    // is:inline /scripts/ URL imports loaded hand-copied duplicates).
    import { decompose, createSpectrogram, createAudioBlob } from 'pleco-xa';

    const {
      processAudioToFingerprints,
      optimizeEqCurves,
      reconstructVocal,
    } = decompose;

    let vocalBuffer = null;
    let mixtureBuffer = null;
    let extractedBuffer = null;

    // Initialize audio context
    function initAudioContext() {
      return new (window.AudioContext || window.webkitAudioContext)();
    }

    // Load audio file
    async function loadAudioFile(file) {
      const ctx = initAudioContext();
      const arrayBuffer = await file.arrayBuffer();
      return await ctx.decodeAudioData(arrayBuffer);
    }

    // Create synthetic demo audio
    function createSyntheticAudio(type, duration = 4.7, sr = 22050) {
      const ctx = initAudioContext();
      const length = Math.floor(sr * duration);
      const buffer = ctx.createBuffer(1, length, sr);
      const data = buffer.getChannelData(0);

      if (type === 'vocal') {
        // Simple vocal-like signal (sine wave with harmonics)
        for (let i = 0; i < length; i++) {
          const t = i / sr;
          const freq = 220; // A3
          data[i] = 0.3 * Math.sin(2 * Math.PI * freq * t) +
                   0.2 * Math.sin(2 * Math.PI * 2 * freq * t) +
                   0.1 * Math.sin(2 * Math.PI * 3 * freq * t);
          // Add some vibrato
          data[i] *= (1 + 0.1 * Math.sin(2 * Math.PI * 5 * t));
        }
      } else if (type === 'mixture') {
        // Mixture: vocal + instrumental
        for (let i = 0; i < length; i++) {
          const t = i / sr;
          // Vocal part
          let vocal = 0.3 * Math.sin(2 * Math.PI * 220 * t) +
                     0.2 * Math.sin(2 * Math.PI * 440 * t) +
                     0.1 * Math.sin(2 * Math.PI * 660 * t);
          vocal *= (1 + 0.1 * Math.sin(2 * Math.PI * 5 * t));

          // Instrumental part (different rhythm)
          const instrument = 0.4 * Math.sin(2 * Math.PI * 330 * t) +
                           0.3 * Math.sin(2 * Math.PI * 165 * t);

          data[i] = vocal + instrument;
        }
      }

      return buffer;
    }

    // Update status
    function updateStatus(text, progress = null) {
      const statusEl = document.getElementById('status');
      const statusText = document.getElementById('statusText');
      const progressBar = document.getElementById('progressBar');

      statusEl.style.display = 'block';
      statusText.textContent = text;

      if (progress !== null) {
        progressBar.style.width = `${progress}%`;
      }
    }

    // Show error
    function showError(message) {
      const errorEl = document.getElementById('error');
      errorEl.textContent = message;
      errorEl.style.display = 'block';
      setTimeout(() => {
        errorEl.style.display = 'none';
      }, 10000);
    }

    // Create spectrogram visualization
    async function createSpectrogramViz(canvas, audioBuffer, title) {
      return await createSpectrogram(canvas, audioBuffer, {
        fftSize: 2048,
        hopLength: 1024,
        colormap: 'viridis',
        minDb: -100,
        maxDb: -10
      });
    }

    // Display fingerprints comparison
    function displayFingerprints(vocalFps, mixtureFps) {
      const metricsGrid = document.getElementById('metricsGrid');
      const vocalRaw = vocalFps['slice_0_raw'][0];
      const mixtureRaw = mixtureFps['slice_0_raw'][0];

      const metrics = [
        { label: 'Mid Energy', vocal: vocalRaw.mid_energy.toFixed(2), mixture: mixtureRaw.mid_energy.toFixed(2) },
        { label: 'Spectral Centroid', vocal: vocalRaw.spectral_centroid.toFixed(0) + ' Hz', mixture: mixtureRaw.spectral_centroid.toFixed(0) + ' Hz' },
        { label: 'Spectral Rolloff', vocal: vocalRaw.spectral_rolloff.toFixed(0) + ' Hz', mixture: mixtureRaw.spectral_rolloff.toFixed(0) + ' Hz' },
        { label: 'Fundamental Freq', vocal: vocalRaw.fundamental_frequency.toFixed(0) + ' Hz', mixture: mixtureRaw.fundamental_frequency.toFixed(0) + ' Hz' },
        { label: 'Num Harmonics', vocal: vocalRaw.num_harmonics, mixture: mixtureRaw.num_harmonics },
        { label: 'Peak to RMS', vocal: vocalRaw.peak_to_rms.toFixed(2), mixture: mixtureRaw.peak_to_rms.toFixed(2) },
        { label: 'Spectral Entropy', vocal: vocalRaw.spectral_entropy.toFixed(3), mixture: mixtureRaw.spectral_entropy.toFixed(3) },
        { label: 'Formant 1', vocal: vocalRaw.formant_1.toFixed(0) + ' Hz', mixture: mixtureRaw.formant_1.toFixed(0) + ' Hz' }
      ];

      metricsGrid.innerHTML = metrics.map(metric => `
        <div class="metric-item">
          <div class="metric-label">${metric.label}</div>
          <div>Vocal: <span class="metric-value">${metric.vocal}</span></div>
          <div>Mixture: <span class="metric-value">${metric.mixture}</span></div>
        </div>
      `).join('');
    }



    // Run vocal separation
    async function runVocalSeparation() {
      const runBtn = document.getElementById('runSeparationBtn');
      const generateBtn = document.getElementById('generateSyntheticBtn');

      try {
        runBtn.disabled = true;
        generateBtn.disabled = true;

        updateStatus('Loading audio files...', 10);

        // Get audio buffers
        if (!vocalBuffer || !mixtureBuffer) {
          throw new Error('Please load both vocal and mixture audio files first');
        }

        updateStatus('Processing vocal audio...', 20);
        const vocalResult = processAudioToFingerprints(vocalBuffer, 2048, 1024);

        updateStatus('Processing mixture audio...', 40);
        const mixtureResult = processAudioToFingerprints(mixtureBuffer, 2048, 1024);

        updateStatus('Optimizing EQ curves...', 60);
        const eqCurves = optimizeEqCurves(
          vocalResult.fingerprints,
          mixtureResult.fingerprints,
          mixtureResult.magnitudeSpec,
          mixtureResult.numWindows,
          mixtureResult.sr,
          100,  // numIterations
          0.01  // learningRate
        );

        updateStatus('Reconstructing vocal...', 80);
        const extractedAudio = reconstructVocal(
          mixtureResult.stftResult,
          eqCurves,
          mixtureResult.sr,
          2048,  // nFft
          1024   // hopLength
        );

        // Create audio buffer for extracted audio
        const ctx = initAudioContext();
        extractedBuffer = ctx.createBuffer(1, extractedAudio.length, mixtureResult.sr);
        extractedBuffer.getChannelData(0).set(extractedAudio);

        updateStatus('Creating visualizations...', 90);

        // Create spectrograms
        await createSpectrogramViz(
          document.getElementById('vocalSpectrogram'),
          vocalBuffer,
          'Target Vocal'
        );

        await createSpectrogramViz(
          document.getElementById('mixtureSpectrogram'),
          mixtureBuffer,
          'Original Mixture'
        );

        await createSpectrogramViz(
          document.getElementById('extractedSpectrogram'),
          extractedBuffer,
          'Extracted Vocal'
        );

        // Show slice example
        const sliceCanvas = document.getElementById('sliceSpectrogram');
        const sliceCtx = sliceCanvas.getContext('2d');
        const sliceData = vocalResult.slices['slice_0_raw'];

        // Simple spectrogram rendering for slice
        const imageData = sliceCtx.createImageData(sliceCanvas.width, sliceCanvas.height);
        const width = sliceCanvas.width;
        const height = sliceCanvas.height;

        for (let x = 0; x < width; x++) {
          for (let y = 0; y < height; y++) {
            const timeIdx = Math.floor((x / width) * sliceData[0].length);
            const freqIdx = Math.floor((y / height) * sliceData.length);
            const val = sliceData[freqIdx][timeIdx] || 0;
            const intensity = Math.min(255, Math.max(0, val * 255));

            const idx = (y * width + x) * 4;
            imageData.data[idx] = intensity;     // R
            imageData.data[idx + 1] = intensity * 0.5; // G
            imageData.data[idx + 2] = intensity * 2;   // B
            imageData.data[idx + 3] = 255;       // A
          }
        }
        sliceCtx.putImageData(imageData, 0, 0);

        // Display fingerprints
        displayFingerprints(vocalResult.fingerprints, mixtureResult.fingerprints);

        // Set up audio playback
        document.getElementById('mixtureAudio').src = URL.createObjectURL(createAudioBlob(mixtureBuffer));
        document.getElementById('vocalAudio').src = URL.createObjectURL(createAudioBlob(vocalBuffer));
        document.getElementById('extractedAudio').src = URL.createObjectURL(createAudioBlob(extractedBuffer));

        // Show optimization results
        const optResults = document.getElementById('optimizationResults');
        optResults.innerHTML = `
          <p>Optimization completed with ${eqCurves.length} EQ curves</p>
          <p>Each curve has 400 frequency points optimized for vocal matching</p>
          <p>Expected quality: 60-80% vocal separation (concept proof)</p>
        `;

        // Show results
        document.getElementById('spectrograms').style.display = 'block';
        document.getElementById('fingerprints').style.display = 'block';
        document.getElementById('results').style.display = 'block';

        updateStatus('Complete!', 100);

      } catch (error) {
        console.error('Error in vocal separation:', error);
        showError(`Error: ${error.message}`);
        updateStatus('Failed', 0);
      } finally {
        runBtn.disabled = false;
        generateBtn.disabled = false;
      }
    }

    // Generate synthetic demo
    async function generateSyntheticDemo() {
      updateStatus('Generating synthetic audio...', 10);

      vocalBuffer = createSyntheticAudio('vocal');
      mixtureBuffer = createSyntheticAudio('mixture');

      updateStatus('Synthetic audio generated. Click "Run Vocal Separation" to process.', 100);
    }

    // Event listeners
    document.getElementById('vocalFile').addEventListener('change', async (e) => {
      if (e.target.files[0]) {
        vocalBuffer = await loadAudioFile(e.target.files[0]);
        updateStatus('Vocal audio loaded', 0);
      }
    });

    document.getElementById('mixtureFile').addEventListener('change', async (e) => {
      if (e.target.files[0]) {
        mixtureBuffer = await loadAudioFile(e.target.files[0]);
        updateStatus('Mixture audio loaded', 0);
      }
    });

    document.getElementById('runSeparationBtn').addEventListener('click', runVocalSeparation);
    document.getElementById('generateSyntheticBtn').addEventListener('click', generateSyntheticDemo);
  </script>
</MainLayout>
