---
interface Props {
  audioBufferVar?: string;
  ctxVar?: string;
  applyLoopVar?: string;
}
const { audioBufferVar = 'currentAudioBuffer', ctxVar = 'audioContext', applyLoopVar = 'applyLoop' } = Astro.props

---

<button
  class="loop-btn"
  id="randomizeLoopBtn12"
  data-buffer-var={audioBufferVar}
  data-ctx-var={ctxVar}
  data-apply-loop-var={applyLoopVar}
>
  🔢 Prime Pulse
</button>

<script>
  import { detectLoop } from '../core/index.js';
  import { enqueueToast } from '../scripts/ui/toastQueue.js';
  import { generatePrimeRhythm, executeOperation } from '../scripts/algorithmic-sequences.js';
  
  function createPrimeSequence(buffer, { steps = 180 } = {}) {
    let loop = detectLoop(buffer);
    const sequence = [];
    const actionSequence = generatePrimeRhythm(steps);
    
    // Prime-based section divisions
    const primes = [7, 11, 13, 17, 19];
    let currentPos = 0;
    const sections = {};
    
    primes.forEach((prime, idx) => {
      const sectionSize = Math.floor(steps * prime / 67); // 67 = sum of primes
      const sectionName = [
        "🔢 Prime Genesis",
        "⚡ Indivisible Surge", 
        "🌟 Crystalline Structure",
        "🔥 Atomic Resonance",
        "🌌 Prime Singularity"
      ][idx];
      
      sections[sectionName] = actionSequence.slice(currentPos, currentPos + sectionSize);
      currentPos += sectionSize;
    });
    
    const createSectionSequence = (section, sectionName) => {
      return section.map((action, idx) => {
        return () => {
          const result = executeOperation(action, buffer, loop);
          buffer = result.buffer;
          loop = result.loop;
          
          return {
            buffer: result.buffer,
            loop: result.loop,
            op: `${sectionName}-${action}-${idx+1}`
          };
        };
      });
    };
    
    Object.entries(sections).forEach(([sectionName, sectionActions]) => {
      sequence.push(...createSectionSequence(sectionActions, sectionName));
    });
    
    return sequence;
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('randomizeLoopBtn12');
    btn?.addEventListener('click', async () => {
      const buffer = window[btn.dataset.bufferVar];
      const ctx = window[btn.dataset.ctxVar];
      const applyLoop = window[btn.dataset.applyLoopVar];
      
      if (!buffer || !ctx || typeof applyLoop !== 'function') return;
      
      const seq = createPrimeSequence(buffer, { steps: 180 });
      enqueueToast('🔢 Prime Pulse: Indivisible Rhythms Activated');
      
      let buf = buffer;
      let currentLoop = detectLoop(buf);
      let section = "";
      
      for (const step of seq) {
        const result = step();
        buf = result.buffer;
        currentLoop = result.loop;
        
        // Detect section changes
        const newSection = result.op.split('-')[0];
        if (newSection !== section) {
          enqueueToast(`${newSection}`);
          section = newSection;
        }
        
        applyLoop(buf, currentLoop, result.op, undefined);
        
        // Prime number timing sequences
        const primeTimings = [2, 3, 5, 7, 11, 13, 17, 19];
        const baseTime = 50;
        const primeIndex = Math.floor(Math.random() * primeTimings.length);
        let timing = baseTime * primeTimings[primeIndex];
        
        // Anti-micro-prime protection - prevent tiny prime chaos
        const minTiming = 90; // Slightly higher for primes
        const maxPrimeSequence = 2; // Very low tolerance for micro-primes
        if (timing < minTiming) {
          const primeCount = (window.primeSequenceCount || 0) + 1;
          window.primeSequenceCount = primeCount;
          
          if (primeCount > maxPrimeSequence) {
            timing = baseTime * 11; // Use a nice prime (11) for recovery
            window.primeSequenceCount = 0;
            enqueueToast('🔢 Prime sequence regulated');
          }
        } else {
          window.primeSequenceCount = 0;
        }
        
        await new Promise(r => setTimeout(r, timing));
      }
      
      enqueueToast('🔢 Prime Pulse Complete - Indivisible Mathematical Perfection');
    });
  });
</script>