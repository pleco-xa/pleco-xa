---
---

<div class="live-speed-controls">
  <button class="loop-btn" id="liveHalfSpeedBtn">
    🐌 Live Half Speed
  </button>

  <button class="loop-btn" id="liveDoubleSpeedBtn">
    🏃 Live Double Speed
  </button>

  <button class="loop-btn" id="liveNormalSpeedBtn">
    ⏸️ Normal Speed
  </button>
</div>

<script>
  import {
    applyLiveHalfSpeed,
    applyLiveDoubleSpeed,
    resetLiveSpeed,
    liveSpeedController,
  } from 'pleco-xa';
  import { enqueueToast } from '../lib/ui/toastQueue.js';
  import { session } from '../scripts/session.js';

  document.addEventListener('DOMContentLoaded', () => {

    // Live Half Speed Button
    const halfBtn = document.getElementById('liveHalfSpeedBtn');
    halfBtn?.addEventListener('click', async () => {
      const buffer = session.currentBuffer;
      const ctx = session.audioContext;
      const applyLoop = session.applyLoop;

      if (!buffer || !ctx) {
        enqueueToast('❌ No audio loaded');
        return;
      }

      try {
        enqueueToast('🐌 Applying live half speed...');

        // Use playbackRate method for immediate response (changes pitch)
        const result = await applyLiveHalfSpeed({
          audioContext: ctx,
          buffer,
          audioProcessor: session.audioProcessor,
        });

        // Update the audio buffer if we got a resampled version
        if (result.buffer) {
          session.setBuffer(result.buffer);
          if (typeof applyLoop === 'function') {
            const loop = { startSample: 0, endSample: result.buffer.length };
            applyLoop(result.buffer, loop, 'half_speed');
          }
        }

        enqueueToast(`✅ Half speed active (${result.method})`);
        console.log('🐌 Half speed result:', result);

      } catch (error) {
        console.error('❌ Live half speed failed:', error);
        enqueueToast(`❌ Half speed failed: ${error.message}`);
      }
    });

    // Live Double Speed Button
    const doubleBtn = document.getElementById('liveDoubleSpeedBtn');
    doubleBtn?.addEventListener('click', async () => {
      const buffer = session.currentBuffer;
      const ctx = session.audioContext;
      const applyLoop = session.applyLoop;

      if (!buffer || !ctx) {
        enqueueToast('❌ No audio loaded');
        return;
      }

      try {
        enqueueToast('🏃 Applying live double speed...');

        // Use playbackRate method for immediate response (changes pitch)
        const result = await applyLiveDoubleSpeed({
          audioContext: ctx,
          buffer,
          audioProcessor: session.audioProcessor,
        });

        // Update the audio buffer if we got a resampled version
        if (result.buffer) {
          session.setBuffer(result.buffer);
          if (typeof applyLoop === 'function') {
            const loop = { startSample: 0, endSample: result.buffer.length };
            applyLoop(result.buffer, loop, 'double_speed');
          }
        }

        enqueueToast(`✅ Double speed active (${result.method})`);
        console.log('🏃 Double speed result:', result);

      } catch (error) {
        console.error('❌ Live double speed failed:', error);
        enqueueToast(`❌ Double speed failed: ${error.message}`);
      }
    });

    // Normal Speed Reset Button
    const normalBtn = document.getElementById('liveNormalSpeedBtn');
    normalBtn?.addEventListener('click', async () => {
      try {
        enqueueToast('⏸️ Resetting to normal speed...');

        const result = await resetLiveSpeed();

        enqueueToast('✅ Normal speed restored');
        console.log('⏸️ Speed reset result:', result);

      } catch (error) {
        console.error('❌ Speed reset failed:', error);
        enqueueToast(`❌ Reset failed: ${error.message}`);
      }
    });

    // Show current speed info on any button click
    [halfBtn, doubleBtn, normalBtn].forEach(btn => {
      btn?.addEventListener('click', () => {
        setTimeout(() => {
          const speedInfo = liveSpeedController.getSpeedInfo();
          console.log('🎛️ Current speed info:', speedInfo);
        }, 100);
      });
    });
  });
</script>

<style>
  .live-speed-controls {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin: 0.5rem 0;
  }

  .live-speed-controls .loop-btn {
    flex: 1;
    min-width: 120px;
  }
</style>
