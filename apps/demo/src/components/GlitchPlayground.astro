---
---
<button id="glitchToggleBtn">Start Glitch</button>

<script>
  // Wave 6 fix: the client script used to reference frontmatter-only
  // variables (audioBufferVar/applyLoopVar) — undefined at runtime in the
  // browser. It now reads the shared session directly.
  import { startBeatGlitch } from 'pleco-xa'
  import { session } from '../scripts/session.js'

  let stop = null
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('glitchToggleBtn')
    btn?.addEventListener('click', () => {
      if (!stop) {
        const buffer = session.currentBuffer
        const applyLoop = session.applyLoop
        if (!buffer || typeof applyLoop !== 'function') return
        stop = startBeatGlitch(buffer, {
          maxOpsPerBar: 1,
          onUpdate: res => applyLoop(res.buffer, res.loop, res.op)
        })
        btn.textContent = 'Stop Glitch'
      } else {
        stop()
        stop = null
        btn.textContent = 'Start Glitch'
      }
    })
  })
</script>

<style>
#glitchToggleBtn { margin-top: .5rem; padding: .4rem .8rem; }
</style>
