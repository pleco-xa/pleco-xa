<button class="loop-btn" id="loopDebugBtn">
  🔍 Debug Loop Detection
</button>

<script>
  import { detectLoop, fastLoopAnalysis, loop } from 'pleco-xa';
  import { enqueueToast } from '../lib/ui/toastQueue.js';
  import { session } from '../scripts/session.js';

  const { findPreciseLoop } = loop;

  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('loopDebugBtn');
    btn?.addEventListener('click', async () => {
      const buffer = session.currentBuffer;

      if (!buffer) {
        enqueueToast('❌ No audio loaded');
        return;
      }
      
      enqueueToast('🔍 Analyzing loop detection...');
      console.log('\n🔍 === LOOP DETECTION DEBUG ===');
      
      // Basic info
      const duration = buffer.duration;
      const sampleRate = buffer.sampleRate;
      console.log(`📊 Audio: ${duration.toFixed(2)}s at ${sampleRate}Hz`);
      
      // Test different detection methods
      try {
        // 1. Simple detectLoop (from loopHelpers)
        const simpleLoop = detectLoop(buffer);
        const simpleStart = simpleLoop.startSample / sampleRate;
        const simpleEnd = simpleLoop.endSample / sampleRate;
        console.log(`📍 Simple detectLoop: ${simpleStart.toFixed(2)}s → ${simpleEnd.toFixed(2)}s (${((simpleEnd-simpleStart)/duration*100).toFixed(1)}% of track)`);
        
        // 2. Fast loop analysis (with timeout protection)
        let fastResult = null;
        try {
          const analysisPromise = fastLoopAnalysis(buffer);
          const timeoutPromise = new Promise((_, reject) => 
            setTimeout(() => reject(new Error('Analysis timeout')), 5000)
          );
          
          fastResult = await Promise.race([analysisPromise, timeoutPromise]);
          
          if (fastResult && fastResult.loop) {
            const fastStart = fastResult.loop.start;
            const fastEnd = fastResult.loop.end;
            console.log(`⚡ Fast analysis: ${fastStart.toFixed(2)}s → ${fastEnd.toFixed(2)}s (${((fastEnd-fastStart)/duration*100).toFixed(1)}% of track)`);
            console.log(`   Score: ${fastResult.loop.score.toFixed(3)}, BPM: ${fastResult.bpm.toFixed(1)}`);
          }
        } catch (error) {
          console.log(`⚡ Fast analysis: FAILED (${error.message}) - skipping`);
          fastResult = null;
        }
        
        // 3. Precise loop detection with different parameters
        const audioData = buffer.getChannelData(0);
        
        // Try conservative settings (current default) with timeout
        let conservativeLoop = null;
        try {
          const conservativePromise = findPreciseLoop(audioData, sampleRate, 120, {
            searchStart: 1.0,
            searchEnd: 0.8,
            minLoopDuration: 2.0,
            maxLoopDuration: 8.0
          });
          const timeoutPromise = new Promise((_, reject) => 
            setTimeout(() => reject(new Error('Timeout')), 3000)
          );
          
          conservativeLoop = await Promise.race([conservativePromise, timeoutPromise]);
          
          if (conservativeLoop) {
            console.log(`🎯 Conservative precise: ${conservativeLoop.start.toFixed(2)}s → ${conservativeLoop.end.toFixed(2)}s (${((conservativeLoop.end-conservativeLoop.start)/duration*100).toFixed(1)}% of track)`);
            console.log(`   Score: ${conservativeLoop.score.toFixed(3)}, Musical bonus: ${conservativeLoop.musicalBonus.toFixed(3)}`);
          }
        } catch (error) {
          console.log(`🎯 Conservative precise: FAILED (${error.message}) - skipping`);
        }
        
        // Try more aggressive settings (search from beginning) with timeout
        let aggressiveLoop = null;
        try {
          const aggressivePromise = findPreciseLoop(audioData, sampleRate, 120, {
            searchStart: 0.1, // Start much earlier
            searchEnd: 0.9,   // Search further
            minLoopDuration: 1.0, // Shorter minimum
            maxLoopDuration: 12.0 // Longer maximum
          });
          const timeoutPromise = new Promise((_, reject) => 
            setTimeout(() => reject(new Error('Timeout')), 3000)
          );
          
          aggressiveLoop = await Promise.race([aggressivePromise, timeoutPromise]);
          
          if (aggressiveLoop) {
            console.log(`🚀 Aggressive precise: ${aggressiveLoop.start.toFixed(2)}s → ${aggressiveLoop.end.toFixed(2)}s (${((aggressiveLoop.end-aggressiveLoop.start)/duration*100).toFixed(1)}% of track)`);
            console.log(`   Score: ${aggressiveLoop.score.toFixed(3)}, Musical bonus: ${aggressiveLoop.musicalBonus.toFixed(3)}`);
          }
        } catch (error) {
          console.log(`🚀 Aggressive precise: FAILED (${error.message}) - skipping`);
        }
        
        // Show percentages for context
        console.log('\n📊 Loop positions as % of track:');
        console.log(`   Simple: ${(simpleStart/duration*100).toFixed(1)}% → ${(simpleEnd/duration*100).toFixed(1)}%`);
        if (fastResult?.loop) {
          console.log(`   Fast: ${(fastResult.loop.start/duration*100).toFixed(1)}% → ${(fastResult.loop.end/duration*100).toFixed(1)}%`);
        }
        if (conservativeLoop) {
          console.log(`   Conservative: ${(conservativeLoop.start/duration*100).toFixed(1)}% → ${(conservativeLoop.end/duration*100).toFixed(1)}%`);
        }
        if (aggressiveLoop) {
          console.log(`   Aggressive: ${(aggressiveLoop.start/duration*100).toFixed(1)}% → ${(aggressiveLoop.end/duration*100).toFixed(1)}%`);
        }
        
        // Analysis
        const midPoint = duration / 2;
        console.log(`\n📍 Track midpoint: ${midPoint.toFixed(2)}s (50%)`);
        
        if (fastResult?.loop) {
          const loopMid = (fastResult.loop.start + fastResult.loop.end) / 2;
          const distanceFromCenter = Math.abs(loopMid - midPoint);
          console.log(`   Fast loop center: ${loopMid.toFixed(2)}s (${(distanceFromCenter < midPoint/2 ? "NEAR" : "FAR FROM")} middle)`);
        }
        
        enqueueToast('🔍 Loop detection analysis complete - check console');
        
      } catch (error) {
        console.error('❌ Loop debug failed:', error);
        enqueueToast(`❌ Debug failed: ${error.message}`);
      }
    });
  });
</script>