        // Restore the previous state
        setCurrentBuffer(previousState.buffer);
        originalAudioBuffer = previousState.originalBuffer;
        session.originalBuffer = originalAudioBuffer;

        // Restore loop points
        const restoredLoop = previousState.loopPoints;
        audioProcessor.setLoopPoints(restoredLoop.start, restoredLoop.end);

        // Restore nudge state
        nudgeState = previousState.nudgeState;
        nudgeEnabled = previousState.nudgeEnabled;
        currentNudgeLoop = previousState.nudgeLoop;
        nudgeReverseState = previousState.nudgeReverseState;

        updateLoopInfo(restoredLoop);
