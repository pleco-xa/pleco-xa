          nudgeState: nudgeState,
          nudgeEnabled: nudgeEnabled,
          nudgeLoop: currentNudgeLoop ? { start: currentNudgeLoop.start, end: currentNudgeLoop.end } : null,
          nudgeReverseState: nudgeReverseState
        });

        const newBuffer = playback.halfSpeedQuantzLoop(currentAudioBuffer, currentLoop, opOptions());
