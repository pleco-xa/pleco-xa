{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2020",
    "skipLibCheck": true,
    "noEmitOnError": false,
    "allowImportingTsExtensions": true,
    "lib": ["ES2020", "DOM", "WebWorker"]
  },
  "include": ["src/**/*.js", "src/**/*.ts"]
}
