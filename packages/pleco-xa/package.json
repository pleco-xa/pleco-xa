{
  "name": "pleco-xa",
  "version": "2.0.5",
  "type": "module",
  "description": "Browser-native audio analysis engine: musical timing, BPM/beat tracking, spectral features, and intelligent loop detection",
  "license": "MIT",
  "author": "Cameron Brooks (https://plecoxa.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pleco-xa/pleco-xa.git"
  },
  "homepage": "https://plecoxa.com",
  "bugs": {
    "url": "https://github.com/pleco-xa/pleco-xa/issues"
  },
  "keywords": [
    "audio",
    "audio-analysis",
    "web-audio",
    "bpm",
    "beat-tracking",
    "loop-detection",
    "mir",
    "music",
    "dsp",
    "spectrogram"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/pleco-xa.js",
  "module": "./dist/pleco-xa.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/pleco-xa.js"
    },
    "./feature": {
      "types": "./dist/types/feature/index.d.ts",
      "import": "./dist/feature.js"
    },
    "./loop": {
      "types": "./dist/types/loop/index.d.ts",
      "import": "./dist/loop.js"
    },
    "./segment": {
      "types": "./dist/types/segment/index.d.ts",
      "import": "./dist/segment.js"
    },
    "./sequence": {
      "types": "./dist/types/sequence/index.d.ts",
      "import": "./dist/sequence.js"
    },
    "./filters": {
      "types": "./dist/types/filters/index.d.ts",
      "import": "./dist/filters.js"
    },
    "./effects": {
      "types": "./dist/types/effects/index.d.ts",
      "import": "./dist/effects.js"
    },
    "./decompose": {
      "types": "./dist/types/decompose/index.d.ts",
      "import": "./dist/decompose.js"
    },
    "./linalg": {
      "types": "./dist/types/linalg/index.d.ts",
      "import": "./dist/linalg.js"
    },
    "./cluster": {
      "types": "./dist/types/cluster/index.d.ts",
      "import": "./dist/cluster.js"
    },
    "./playback": {
      "types": "./dist/types/playback/ops.d.ts",
      "import": "./dist/playback.js"
    },
    "./convert": {
      "types": "./dist/types/scripts/xa-convert.d.ts",
      "import": "./dist/convert.js"
    },
    "./bpm": {
      "types": "./dist/types/scripts/xa-bpm-algorithm.d.ts",
      "import": "./dist/bpm.js"
    },
    "./notation": {
      "types": "./dist/types/scripts/xa-notation.d.ts",
      "import": "./dist/notation.js"
    },
    "./recurrence": {
      "types": "./dist/types/scripts/xa-recurrence.d.ts",
      "import": "./dist/recurrence.js"
    },
    "./audioio": {
      "types": "./dist/types/scripts/xa-audioio.d.ts",
      "import": "./dist/audioio.js"
    },
    "./intervals": {
      "types": "./dist/types/scripts/xa-intervals.d.ts",
      "import": "./dist/intervals.js"
    },
    "./fileio": {
      "types": "./dist/types/scripts/xa-fileio.d.ts",
      "import": "./dist/fileio.js"
    },
    "./file": {
      "types": "./dist/types/scripts/xa-file.d.ts",
      "import": "./dist/file.js"
    },
    "./io": {
      "types": "./dist/types/io/wav.d.ts",
      "import": "./dist/io.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "docs/",
    "llms.txt",
    "api-manifest.json",
    "VERIFICATION.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "rollup -c && rollup -c rollup.subpaths.config.js && (tsc -p tsconfig.build.json || true) && node ../../tools/generate-llms.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:types": "node ../../tools/check-types.mjs",
    "prepublishOnly": "npm run build && npm run test && npm run check:types"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.1",
    "jsdom": "^29.1.1",
    "rollup": "^4.24.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "vitest": "^4.1.10",
    "typescript": "^7.0.2"
  },
  "types": "./dist/types/index.d.ts"
}
