---
interface Props {
  audioBufferVar?: string;
  ctxVar?: string;
  applyLoopVar?: string;
}
const { audioBufferVar = 'currentAudioBuffer', ctxVar = 'audioContext', applyLoopVar = 'applyLoop' } = Astro.props

---

<button
  class="loop-btn"
  id="randomizeLoopBtn11"
  data-buffer-var={audioBufferVar}
  data-ctx-var={ctxVar}
  data-apply-loop-var={applyLoopVar}
>
  🌊 Fibonacci Flow
</button>

<script>
  import { detectLoop } from '../core/index.js';
  import { enqueueToast } from '../scripts/ui/toastQueue.js';
  import { generateFibonacci, executeOperation } from '../scripts/algorithmic-sequences.js';
  
  function createFibonacciSequence(buffer, { steps = 128 } = {}) {
    let loop = detectLoop(buffer);
    const sequence = [];
    const actionSequence = generateFibonacci(steps);
    
    // Create musical sections based on Fibonacci ratios
    const goldenRatio = 1.618;
    const sections = {
      intro: actionSequence.slice(0, Math.floor(steps / goldenRatio / goldenRatio)),
      verse: actionSequence.slice(Math.floor(steps / goldenRatio / goldenRatio), Math.floor(steps / goldenRatio)),
      chorus: actionSequence.slice(Math.floor(steps / goldenRatio), Math.floor(steps * goldenRatio / (goldenRatio + 1))),
      bridge: actionSequence.slice(Math.floor(steps * goldenRatio / (goldenRatio + 1)), Math.floor(steps * 0.9)),
      outro: actionSequence.slice(Math.floor(steps * 0.9))
    };
    
    const createSectionSequence = (section, sectionName) => {
      return section.map((action, idx) => {
        return () => {
          const result = executeOperation(action, buffer, loop);
          buffer = result.buffer;
          loop = result.loop;
          
          return {
            buffer: result.buffer,
            loop: result.loop,
            op: `${sectionName}-${action}-${idx+1}`
          };
        };
      });
    };
    
    sequence.push(...createSectionSequence(sections.intro, "📐 Golden Intro"));
    sequence.push(...createSectionSequence(sections.verse, "🌱 Fibonacci Growth"));
    sequence.push(...createSectionSequence(sections.chorus, "🌸 Spiral Bloom"));
    sequence.push(...createSectionSequence(sections.bridge, "🔄 Recursive Bridge"));
    sequence.push(...createSectionSequence(sections.outro, "♾️ Infinite Outro"));
    
    return sequence;
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('randomizeLoopBtn11');
    btn?.addEventListener('click', async () => {
      const buffer = window[btn.dataset.bufferVar];
      const ctx = window[btn.dataset.ctxVar];
      const applyLoop = window[btn.dataset.applyLoopVar];
      
      if (!buffer || !ctx || typeof applyLoop !== 'function') return;
      
      const seq = createFibonacciSequence(buffer, { steps: 128 });
      enqueueToast('🌊 Fibonacci Flow: Golden Ratio Composition');
      
      let buf = buffer;
      let currentLoop = detectLoop(buf);
      let section = "";
      
      for (const step of seq) {
        const result = step();
        buf = result.buffer;
        currentLoop = result.loop;
        
        // Detect section changes
        const newSection = result.op.split('-')[0];
        if (newSection !== section) {
          enqueueToast(`${newSection}`);
          section = newSection;
        }
        
        applyLoop(buf, currentLoop, result.op, undefined);
        
        // Fibonacci-based timing
        const timing = 
          section.includes("Intro") ? 233 :  // Fibonacci number
          section.includes("Growth") ? 144 :  // Fibonacci number  
          section.includes("Bloom") ? 89 :    // Fibonacci number
          section.includes("Bridge") ? 55 :   // Fibonacci number
          section.includes("Outro") ? 377 : 144; // Fibonacci numbers
        
        await new Promise(r => setTimeout(r, timing));
      }
      
      enqueueToast('🌊 Fibonacci Flow Complete - Natural Mathematical Beauty');
    });
  });
</script>